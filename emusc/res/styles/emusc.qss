    );

    border: 1px solid #080808;
    border-radius: 10px;

    color: #e0e0e0;
    padding: 6px 12px;
}

/* Invert the gradient when pressed to simulate the button physically pressed */
SynthButton#Round:pressed {
    background-color: qlineargradient(
        x1: 0, y1: 0, 
        x2: 1, y2: 1, 
        stop: 0 #1d1d1d,   /* Top-left goes dark as it moves away from light */
        stop: 0.5 #111111, 
        stop: 1.0 #1c1c1c  /* Bottom-right catches a bit of ambient bounce light */
    );
    padding-top: 7px;      /* Subtle layout shift to simulate a physical click */
    padding-left: 13px;
}


VolumeDial {
    background-color: #00000000;
}